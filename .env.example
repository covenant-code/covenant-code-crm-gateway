# Combined stack environment (gateway + crm-service + postgres)
# Copy to .env and fill in values before deploying
# Deploy: export $(cat .env | xargs) && docker stack deploy -c docker-stack.yml cccrm --with-registry-auth

# Database (used by crm-service)
DB_NAME=crm_db
DB_USER=crm_user

# Frontend origin for CORS — exact domain, e.g. https://app.yourcompany.com
CORS_ALLOWED_ORIGIN=https://your-frontend-domain.com

# Docker registry
REGISTRY=registry.example.com

# Image tags — can differ between gateway and crm-service
GATEWAY_IMAGE_TAG=latest
CRM_IMAGE_TAG=latest
